prefix_rule(
    pattern = ["git", "commit", "-m", "fix: sync picker with external playback"],
    decision = "allow",
)

prefix_rule(
    pattern = ["git", "push", "-u", "origin", "codex/2026-01-22-media-list-active-file"],
    decision = "allow",
)

prefix_rule(
    pattern = ["gh", "pr", "create", "--base", "main", "--head", "codex/2026-01-22-media-list-active-file", "--title", "fix: sync picker on external playback", "--body", "## Summary\\n- sync selected item to current playback only when no pending command and picker is closed\\n- track active picker device to avoid overriding operator intent\\n\\n## Testing\\n- Not run (not requested)\\n\\n## Bead\\n- orchestrator-zyys"],
    decision = "allow",
)

prefix_rule(
    pattern = ["/bin/zsh", "-lc", "cd '/Users/dalecarman/Groove Jones Dropbox/Dale Carman/Projects/dev/codex-orchestrator' && git add -A && git diff --cached --stat"],
    decision = "allow",
)
prefix_rule(pattern=["git", "branch", "-m"], decision="allow")
prefix_rule(pattern=["git", "checkout", "-b", "feat/91"], decision="allow")
