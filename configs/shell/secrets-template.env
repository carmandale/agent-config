#==============================================================================
# ~/.secrets/agent-keys.env — API keys loaded as environment variables
#
# This file is NOT tracked in git. Each machine has its own copy.
# Permissions MUST be 600 (owner read/write only).
#
# Loaded by ~/.zshenv via: set -a; source this-file; set +a
#
# Aligns with OpenClaw secrets env provider:
#   { source: "env", provider: "default", id: "OPENAI_API_KEY" }
#
# Format: KEY=value (no export needed, set -a handles it)
#==============================================================================

# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=AI...
# XAI_API_KEY=xai-...
# BRAVE_API_KEY=BS...
# PARALLEL_API_KEY=...
# OPENROUTER_API_KEY=...
# MINIMAX_API_KEY=...
# SUPERMEMORY_API_KEY=...
# FACTORY_API_KEY=...
# CLOUDFLARE_API_TOKEN=...
# TAVILY_API_KEY=tvly-...
# FREEPIK_API_KEY=...
# FINANCIAL_DATASETS_API_KEY=...
