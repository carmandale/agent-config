#!/usr/bin/env bash
#==============================================================================
# post-receive hook (mini-ts)
# Fires after receiving a push. Runs install + Gemini convert.
#==============================================================================

REPO_DIR="$(cd "$(git rev-parse --git-dir)/.." && pwd)"

info()  { echo -e "\033[0;34m▸ agent-config (mini-ts):\033[0m $1" >&2; }
ok()    { echo -e "\033[0;32m✓ agent-config (mini-ts):\033[0m $1" >&2; }
warn()  { echo -e "\033[1;33m⚠ agent-config (mini-ts):\033[0m $1" >&2; }

# Regenerate Gemini TOML commands
GEMINI_SCRIPT="$REPO_DIR/scripts/convert-commands-gemini.sh"
if [[ -x "$GEMINI_SCRIPT" ]]; then
    if bash "$GEMINI_SCRIPT" >/dev/null 2>&1; then
        ok "Gemini TOML commands regenerated"
    else
        warn "Gemini TOML conversion failed"
    fi
fi

# Run install to ensure symlinks + hooks are current
if bash "$REPO_DIR/install.sh" >/dev/null 2>&1; then
    ok "install.sh completed"
else
    warn "install.sh failed"
fi

ok "Post-receive sync complete"
exit 0
