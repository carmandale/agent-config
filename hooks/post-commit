#!/usr/bin/env bash
#==============================================================================
# post-commit hook for agent-config
#
# After every commit, ensures all derived artifacts and remote machines
# are in sync. Runs fast (<5s locally, async for remote).
#==============================================================================

set -euo pipefail

REPO_DIR="$(git rev-parse --show-toplevel)"

# Colors (stderr only — hooks should be quiet on stdout)
info()  { echo -e "\033[0;34m▸ agent-config:\033[0m $1" >&2; }
ok()    { echo -e "\033[0;32m✓ agent-config:\033[0m $1" >&2; }
warn()  { echo -e "\033[1;33m⚠ agent-config:\033[0m $1" >&2; }

#==============================================================================
# 1. Regenerate Gemini TOML commands (local)
#    Gemini can't read .md — needs generated .toml copies
#==============================================================================
GEMINI_SCRIPT="$REPO_DIR/scripts/convert-commands-gemini.sh"
if [[ -x "$GEMINI_SCRIPT" ]]; then
    if bash "$GEMINI_SCRIPT" >/dev/null 2>&1; then
        ok "Gemini TOML commands regenerated"
    else
        warn "Gemini TOML conversion failed — run manually: bash $GEMINI_SCRIPT"
    fi
else
    info "Gemini converter not found — skipping"
fi

#==============================================================================
# 2. Verify local symlinks are intact
#    Quick check that the critical symlinks still point where they should.
#    Does NOT run full install.sh — just validates.
#==============================================================================
COMMANDS_DIR="$REPO_DIR/commands"
SKILLS_DIR="$REPO_DIR/skills"
AGENTS_MD="$REPO_DIR/instructions/AGENTS.md"

broken=0
check_link() {
    local link="$1" target="$2"
    if [[ -L "$link" ]]; then
        local actual
        actual="$(readlink "$link")"
        if [[ "$actual" != "$target" ]]; then
            warn "Symlink drift: $link → $actual (expected $target)"
            broken=1
        fi
    elif [[ ! -e "$link" ]]; then
        warn "Missing symlink: $link"
        broken=1
    fi
}

check_link "$HOME/.claude/commands"          "$COMMANDS_DIR"
check_link "$HOME/.claude/skills"            "$SKILLS_DIR"
check_link "$HOME/.pi/agent/prompts"         "$COMMANDS_DIR"
check_link "$HOME/.codex/prompts"            "$COMMANDS_DIR"
check_link "$HOME/.config/opencode/commands" "$COMMANDS_DIR"
check_link "$HOME/.agents/skills"            "$SKILLS_DIR"

if [[ "$broken" -eq 1 ]]; then
    warn "Broken symlinks detected — run: bash $REPO_DIR/install.sh"
else
    ok "Local symlinks verified"
fi

#==============================================================================
# 3. Hygiene checks
#==============================================================================
# Note: mini-ts sync is handled by git push (dual push URL + post-receive hook).
# No need to sync here — it happens automatically when you push.

# Check for .md commands missing frontmatter (agent discovery depends on it)
for f in "$COMMANDS_DIR"/*.md; do
    if [[ -f "$f" ]] && ! head -1 "$f" | grep -q "^---$"; then
        warn "Missing frontmatter: $(basename "$f")"
    fi
done

# Check for skills missing SKILL.md
for d in "$SKILLS_DIR"/*/; do
    # Skip symlinks (top-level aliases) and hidden dirs
    if [[ -L "${d%/}" ]] || [[ "$(basename "$d")" == .* ]]; then
        continue
    fi
    if [[ -d "$d" ]] && [[ -f "$d/SKILL.md" ]]; then
        # Leaf skill with SKILL.md — good
        continue
    elif [[ -d "$d" ]]; then
        # Category dir (domain/, meta/, tools/, etc.) — check leaf subdirs only
        for sub in "$d"*/; do
            if [[ -d "$sub" ]] && [[ ! -L "${sub%/}" ]] && [[ "$(basename "$sub")" != .* ]]; then
                # Check if this is a leaf (has no subdirs) or a sub-category
                has_subdirs=false
                for subsub in "$sub"*/; do
                    if [[ -d "$subsub" ]] && [[ ! -L "${subsub%/}" ]]; then
                        has_subdirs=true
                        break
                    fi
                done
                if [[ "$has_subdirs" == false ]] && [[ ! -f "$sub/SKILL.md" ]]; then
                    warn "Missing SKILL.md: $(basename "$d")/$(basename "$sub")"
                fi
            fi
        done
    fi
done

ok "Post-commit checks complete"
exit 0
